{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/api/waze-feed", "destination": "/api/waze-feed" },
    { "source": "/api/waze-tvt", "destination": "/api/waze-tvt" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
